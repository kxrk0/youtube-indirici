{
  "manifest_version": 3,
  "name": "Universal Downloader Companion",
  "version": "2.1",
  "description": "Download videos & audio from YouTube, YouTube Music, SoundCloud, TikTok, Instagram, Twitter, Vimeo, Twitch, Bandcamp, Reddit and more.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "notifications",
    "contextMenus",
    "downloads"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "*://player.vimeo.com/*",
    "*://api.dailymotion.com/*",
    "*://www.youtube.com/*",
    "*://music.youtube.com/*",
    "*://soundcloud.com/*",
    "*://open.spotify.com/*",
    "*://bandcamp.com/*",
    "*://*.bandcamp.com/*",
    "*://www.tiktok.com/*",
    "*://www.instagram.com/*",
    "*://twitter.com/*",
    "*://x.com/*",
    "*://vimeo.com/*",
    "*://www.dailymotion.com/*",
    "*://www.twitch.tv/*",
    "*://clips.twitch.tv/*",
    "*://www.reddit.com/*",
    "*://old.reddit.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://music.youtube.com/*",
        "*://soundcloud.com/*",
        "*://open.spotify.com/*",
        "*://bandcamp.com/*",
        "*://*.bandcamp.com/*",
        "*://www.tiktok.com/*",
        "*://www.instagram.com/*",
        "*://twitter.com/*",
        "*://x.com/*",
        "*://vimeo.com/*",
        "*://www.dailymotion.com/*",
        "*://www.twitch.tv/*",
        "*://clips.twitch.tv/*",
        "*://www.reddit.com/*",
        "*://old.reddit.com/*"
      ],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Universal Downloader Companion"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/icon16.png", "icons/icon48.png", "icons/icon128.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
